# Application
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urlshortener
DB_HOST=localhost
DB_PORT=5432
DB_NAME=urlshortener
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Short code
SHORT_CODE_LENGTH=8

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# Cache TTL in seconds (default: 24 hours)
CACHE_TTL=86400

# JWT — generate strong random secrets in production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-use-a-different-value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# bcrypt work factor (higher = slower hash, more secure; 12 is a good default)
BCRYPT_ROUNDS=12
